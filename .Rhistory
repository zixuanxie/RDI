class1models = intersect(class1, common)
class2models = intersect(class2, common)
models = c(class1models,class2models)
group = factor(c(rep("Sen",length(class1models)),rep("Insen",length(class2models))))
sample_anno = as.data.frame(group,models)
design <- model.matrix(~0 + group)
colnames(design) <- levels(group)
fit <- lmFit(expr.gs[,models], design)
contrast.matrix <- makeContrasts("Sen-Insen", levels=design)
fit2 <- contrasts.fit(fit, contrast.matrix)
fit2 <- eBayes(fit2)
DE.gs <- topTable(fit2,number=nrow(fit2), adjust="none",coef="Sen-Insen")
paths = row.names(DE.gs)
geneids=unlist(lapply(gsc[paths], function(x)paste(geneIds(x),collapse = ",")))
DE.gs[,"Pathway"]=paths
DE.gs[,"Involved genes"]=geneids
DE.gs = DE.gs[order(DE.gs$P.Value),c(7,1,2,4,5,8)]
write.xlsx(DE.gs,paste0(project," data-",compound,".xlsx"),sheetName = "DE genesets",row.names = F,append = T)
expr.gs <- gsva(gsvaParam(as.matrix(expr[,common]),gsc),verbose=F)
class1models = intersect(class1, common)
class2models = intersect(class2, common)
models = c(class1models,class2models)
group = factor(c(rep("Sen",length(class1models)),rep("Insen",length(class2models))))
sample_anno = as.data.frame(group,models)
design <- model.matrix(~0 + group)
colnames(design) <- levels(group)
fit <- lmFit(expr.gs[,models], design)
contrast.matrix <- makeContrasts("Sen-Insen", levels=design)
fit2 <- contrasts.fit(fit, contrast.matrix)
fit2 <- eBayes(fit2)
DE.gs <- topTable(fit2,number=nrow(fit2), adjust="none",coef="Sen-Insen")
paths = row.names(DE.gs)
geneids=unlist(lapply(gsc[paths], function(x)paste(geneIds(x),collapse = ",")))
DE.gs[,"Pathway"]=paths
DE.gs[,"Involved genes"]=geneids
DE.gs = DE.gs[order(DE.gs$P.Value),c(7,1,2,4,5,8)]
write.xlsx(DE.gs,paste0(project," data-",compound,".xlsx"),sheetName = "DE genesets",row.names = F,append = T)
